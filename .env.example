# Postgres (docker-compose)
POSTGRES_DB=futbet
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Spring Boot
DB_URL=jdbc:postgresql://localhost:5432/futbet
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (gere um secret aleatorio com pelo menos 32 bytes em producao)
JWT_SECRET=change-me-in-production-this-is-a-long-development-secret-key-with-256-bits-minimum
